#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
FIRST_LINE="$(head -n1 "$MSG_FILE" | tr -d '\r')"

# Allow merge/revert commits generated by git
if [[ "$FIRST_LINE" =~ ^Merge\  ]] || [[ "$FIRST_LINE" =~ ^Revert\  ]]; then
  exit 0
fi

PATTERN='^(feat|fix|refactor|docs|test|chore|perf|build|ci|revert)(\([a-z0-9._-]+\))?: .{8,}$'

if ! [[ "$FIRST_LINE" =~ $PATTERN ]]; then
  echo "❌ Invalid commit message format."
  echo "Use: type(scope): descriptive summary"
  echo "Example: feat(frontend): add student brand explore section"
  echo "Allowed types: feat, fix, refactor, docs, test, chore, perf, build, ci, revert"
  exit 1
fi
